Table "account" {
  "userId" uuid [not null]
  "type" text [not null]
  "provider" text [not null]
  "providerAccountId" text [not null]
  "refresh_token" text
  "access_token" text
  "expires_at" int4
  "token_type" text
  "scope" text
  "id_token" text
  "session_state" text
}

Table "session" {
  "sessionToken" text [pk, not null]
  "userId" uuid [not null]
  "expires" timestamp [not null]
}

Table "user" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "name" varchar(255)
  "email" varchar(320) [unique, not null]
  "emailVerified" timestamp
  "image" varchar(2048)
  "role" roles [default: 'coach']
  "username" varchar(25) [unique]
  "access" access [default: 'read/write']
  "is_active" bool [default: true]
  "facility_id" uuid

  Indexes {
    facility_id [type: btree, name: "user_facility_idx"]
  }
}

Table "player_information" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "userId" uuid
  "height" float4 [not null]
  "weight" float4 [not null]
  "position" text [not null]
  "throws" text [not null]
  "hits" text [not null]
  "first_name" text [not null]
  "last_name" text [not null]
  "profile_picture_url" text
  "date_of_birth" date
  "prospect" bool [not null, default: false]
  "created_at" timestamp [not null, default: `now()`]
  "updated_at" timestamp [not null, default: `now()`]
  "sport" sports [not null, default: 'baseball']
  "primary_coach_id" uuid
  "facility_id" uuid

  Indexes {
    facility_id [type: btree, name: "player_information_facility_idx"]
    userId [type: btree, name: "player_information_user_id_idx"]
  }
}

Table "notes" {
  "id" uuid [pk, not null, default: `gen_random_uuid()`]
  "userId" uuid [not null]
