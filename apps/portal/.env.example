# Portal app environment
# Required in production and staging unless marked optional.
# Vercel supplies NODE_ENV=production during production builds.

NODE_ENV=development

# Required: Auth.js secret and Resend magic-link provider config.
AUTH_SECRET=replace-with-auth-secret
AUTH_RESEND_KEY=replace-with-resend-api-key
AUTH_RESEND_FROM=no-reply@example.com

# Required: database used by Portal pages and Auth.js adapter.
DATABASE_URL=postgres://user:password@host:5432/database

# Required: API proxy target for server-side calls from Portal to apps/api.
API_BASE_URL=https://api-staging.example.com
# Required: must match apps/api and apps/ams for the same environment.
# Use a high-entropy value of at least 32 characters.
API_INTERNAL_AUTH_SECRET=replace-with-at-least-32-characters

# Optional: Auth.js v5 usually infers these on Vercel. Document/set only if needed.
# AUTH_URL=https://portal.example.com
# AUTH_TRUST_HOST=true
