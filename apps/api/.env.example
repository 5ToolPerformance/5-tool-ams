# API app environment

NODE_ENV=development

# Database
DATABASE_URL=postgres://user:password@host:5432/database

# Internal API authentication
# Must match apps/ams and apps/portal. Use a high-entropy value of at least 32 characters.
API_INTERNAL_AUTH_SECRET=replace-with-at-least-32-characters

# API-owned cron routes
CRON_SECRET=replace-with-cron-secret

# Portal email links/notifications
PORTAL_APP_URL=https://portal-staging.example.com
PORTAL_EMAIL_API_KEY=replace-with-email-api-key
PORTAL_EMAIL_FROM=no-reply@example.com

# ArmCare integration. Required only for the API deployment that runs ArmCare sync.
ARMCARE_STATUS=staging
ARMCARE_USERNAME=replace-with-armcare-username
ARMCARE_PASSWORD=replace-with-armcare-password
ARMCARE_AUTH_URL_STAGING=https://armcare-staging.example.com/auth
ARMCARE_API_URL_STAGING=https://armcare-staging.example.com/api
ARMCARE_AUTH_URL_PROD=https://armcare.example.com/auth
ARMCARE_API_URL_PROD=https://armcare.example.com/api

# Azure attachment/file storage
AZURE_STORAGE_ACCOUNT_NAME=replace-with-storage-account
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=replace-with-storage-account;AccountKey=replace-with-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=attachments

# Optional local/non-serverless PDF runtime override
# PUPPETEER_EXECUTABLE_PATH=/path/to/chromium
