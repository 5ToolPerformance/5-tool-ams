# AMS app environment
# Required in production and staging unless marked optional.
# Vercel supplies NODE_ENV=production during production builds.

NODE_ENV=development

# Required: database used by AMS pages and Auth.js adapter.
DATABASE_URL=postgres://user:password@host:5432/database

# Required: API proxy target for server-side calls from AMS to apps/api.
API_BASE_URL=https://api-staging.example.com
# Required: must match apps/api and apps/portal for the same environment.
# Use a high-entropy value of at least 32 characters.
API_INTERNAL_AUTH_SECRET=replace-with-at-least-32-characters

# Required: Auth.js cookie/JWT secret.
AUTH_SECRET=replace-with-auth-secret

# Required: Google OAuth for AMS sign-in.
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Required: Microsoft Entra ID OAuth for AMS sign-in.
AUTH_MICROSOFT_ENTRA_ID_ID=replace-with-microsoft-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=replace-with-microsoft-client-secret
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/tenant-id/v2.0

# Optional: Auth.js v5 usually infers these on Vercel. Document/set only if needed.
# AUTH_URL=https://ams.example.com
# AUTH_TRUST_HOST=true
# AUTH_REDIRECT_PROXY_URL=https://ams.example.com/api/auth

# Optional: local/non-serverless PDF runtime override.
# PUPPETEER_EXECUTABLE_PATH=/path/to/chromium
